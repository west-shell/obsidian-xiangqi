{
  "name": "obsidian-xiangqi",
  "private": true,
  "version": "3.9.8",
  "description": "Render xiangqi(Chinese chess) positions diagrams in a note.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "fmt": "prettier --write src",
    "fmt:check": "prettier --check src",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "dev": "vite build --mode development && node -e \"require('fs').copyFileSync('manifest.json', './test-vault/.obsidian/plugins/xiangqi/manifest.json')\"",
    "build": "vite build --mode production && node -e \"require('fs').copyFileSync('manifest.json', 'build/manifest.json')\"",
    "build:min": "vite build --mode production-min && node -e \"require('fs').copyFileSync('manifest.json', 'build/manifest.json')\"",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:watch": "vitest watch",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "svelte",
    "svelte5",
    "typescript"
  ],
  "author": "weshell",
  "authorUrl": "https://space.bilibili.com/156446344",
  "license": "GPL-3.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.3.0",
    "@west-shell/xiangqi.js": "file:../xiangqi.js",
    "@west-shell/xiangqiground": "file:../xiangqiground",
    "d3": "^7.9.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^17.7.0",
    "obsidian": "^1.13.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.8.0",
    "tslib": "^2.6.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.0",
    "vitest": "^3.2.4"
  }
}
